### IntelliJ IDEA ###
# Commit project-level config (modules, misc, encodings, vcs) so IntelliJ
# marks target/ as excluded on first open — prevents editing compiled output.
# Ignore only user-specific files that differ per machine.
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/
.idea/httpRequests/
.idea/sonarlint/
*.iws
*.ipr
# Ignore all .iml files except the root module file
*.iml
!PelletPursuit.iml

